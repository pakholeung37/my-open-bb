APP_ENVIRONMENT=development
APP_DATABASE_PATH=/data/openbb_platform.duckdb
APP_WATCHLIST_PATH=/app/configs/watchlist.yaml
APP_FEEDS_PATH=/app/configs/feeds.yaml
APP_REFRESH_INTERVAL_MINUTES=5
APP_MANUAL_REFRESH_COOLDOWN_SECONDS=60
APP_MARKET_QUOTE_TTL_SECONDS=300
APP_MARKET_DEFAULT_LOOKBACK_DAYS=30
APP_MARKET_PROVIDER=yfinance
APP_ENABLE_SCHEDULER=true
APP_FRONTEND_ORIGIN=http://localhost:7000
VITE_API_BASE_URL=/api/v1
VITE_PROXY_TARGET=http://127.0.0.1:8000
